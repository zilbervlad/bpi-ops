{% extends "base.html" %}

{% block title %}Forms Admin | BPI Ops{% endblock %}
{% block header %}Forms Admin{% endblock %}

{% block content %}
<div class="content-grid">
    <div class="card">
        <div class="card-header">
            <div>
                <h3>Create Form</h3>
                <p class="muted">Build reusable BPI Ops forms without creating a brand-new module every time.</p>
            </div>
        </div>

        <form method="post" class="admin-form">
            <label>Form Title</label>
            <input type="text" name="title" placeholder="Example: Morning Inspection" required>

            <label>Description</label>
            <textarea name="description" rows="3" placeholder="What is this form used for?"></textarea>

            <div class="role-grid">
                <div>
                    <h4>Can Submit</h4>
                    {% for role in role_options %}
                    <label class="check-row"><input type="checkbox" name="submit_roles" value="{{ role }}" {% if role in ['admin','supervisor','manager','general_manager'] %}checked{% endif %}> {{ role|replace('_',' ')|title }}</label>
                    {% endfor %}
                </div>
                <div>
                    <h4>Can View</h4>
                    {% for role in role_options %}
                    <label class="check-row"><input type="checkbox" name="view_roles" value="{{ role }}" {% if role in ['admin','supervisor','manager','general_manager'] %}checked{% endif %}> {{ role|replace('_',' ')|title }}</label>
                    {% endfor %}
                </div>
            </div>

            <button class="btn" type="submit">Create Form</button>
        </form>
    </div>

    <div class="card">
        <div class="card-header">
            <div>
                <h3>Existing Forms</h3>
                <p class="muted">Edit questions, scoring, and access.</p>
            </div>
        </div>

        <div class="table-wrap">
            <table class="data-table">
                <thead>
                    <tr><th>Form</th><th>Status</th><th>Questions</th><th></th></tr>
                </thead>
                <tbody>
                {% for template in templates %}
                    <tr>
                        <td>{{ template.title }}</td>
                        <td>{{ "Active" if template.is_active else "Inactive" }}</td>
                        <td>{{ template.questions|length }}</td>
                        <td><a href="{{ url_for('forms.edit_template', template_id=template.id) }}">Edit</a></td>
                    </tr>
                {% else %}
                    <tr><td colspan="4">No forms yet.</td></tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
.admin-form { display:grid; gap:12px; }
.admin-form input[type="text"], .admin-form textarea { width:100%; border:1px solid #d0d5dd; border-radius:12px; padding:11px 12px; font:inherit; box-sizing:border-box; }
.admin-form label { font-weight:800; }
.role-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(180px,1fr)); gap:16px; }
.check-row { display:block; font-weight:500 !important; margin:8px 0; }
</style>
{% endblock %}
