{% extends "base.html" %}

{% block title %}Form Submissions | BPI Ops{% endblock %}
{% block header %}Form Submissions{% endblock %}

{% block content %}
<div class="card">
    <div class="card-header">
        <div>
            <h3>Form Submissions</h3>
            <p class="muted">Review submitted forms by store, form, and score.</p>
        </div>
        <a class="btn secondary" href="{{ url_for('forms.index') }}">Back to Forms</a>
    </div>

    <form method="get" class="filter-row">
        <select name="template_id">
            <option value="">All forms</option>
            {% for template in templates %}
                <option value="{{ template.id }}" {% if selected_template_id == template.id %}selected{% endif %}>{{ template.title }}</option>
            {% endfor %}
        </select>

        <select name="store_number">
            <option value="">All stores</option>
            {% for store in stores %}
                <option value="{{ store.store_number }}" {% if selected_store_number == store.store_number %}selected{% endif %}>{{ store.store_number }}</option>
            {% endfor %}
        </select>

        <button class="btn" type="submit">Filter</button>
        <a class="btn secondary" href="{{ url_for('forms.submissions') }}">Clear</a>
    </form>

    <div class="table-wrap">
        <table class="data-table">
            <thead>
                <tr>
                    <th>Submitted</th>
                    <th>Form</th>
                    <th>Store</th>
                    <th>By</th>
                    <th>Score</th>
                    <th>Fails</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            {% for submission in submissions %}
                <tr>
                    <td>{{ submission.submitted_at.strftime('%m/%d/%Y %I:%M %p') }}</td>
                    <td>{{ submission.template.title }}</td>
                    <td>{{ submission.store_number }}</td>
                    <td>{{ submission.submitted_by.name if submission.submitted_by else "Unknown" }}</td>
                    <td>
                        {% if submission.score_possible > 0 %}
                            <strong>{{ submission.score_percent }}% · {{ submission.grade }}</strong>
                        {% else %}
                            —
                        {% endif %}
                    </td>
                    <td>
                        {{ submission.failed_count }}
                        {% if submission.critical_failed_count > 0 %}
                            <span class="critical-pill">{{ submission.critical_failed_count }} critical</span>
                        {% endif %}
                    </td>
                    <td><a href="{{ url_for('forms.submission_detail', submission_id=submission.id) }}">View</a></td>
                </tr>
            {% else %}
                <tr><td colspan="7">No submissions found.</td></tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>

<style>
.filter-row { display:flex; gap:10px; flex-wrap:wrap; margin:18px 0; }
.filter-row select { border:1px solid #d0d5dd; border-radius:12px; padding:10px 12px; }
.critical-pill { display:inline-block; margin-left:6px; background:#fee2e2; color:#991b1b; padding:3px 8px; border-radius:999px; font-size:11px; font-weight:800; }
</style>
{% endblock %}
