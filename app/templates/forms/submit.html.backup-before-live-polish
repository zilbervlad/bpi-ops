{% extends "base.html" %}

{% block title %}{{ template.title }} | BPI Ops{% endblock %}
{% block header %}{{ template.title }}{% endblock %}

{% block content %}
<div class="card">
    <div class="card-header">
        <div>
            <h3>{{ template.title }}</h3>
            <p class="muted">{{ template.description }}</p>
        </div>
        <a class="btn secondary" href="{{ url_for('forms.index') }}">Back to Forms</a>
    </div>

    <form method="post" class="bpi-form">
        <div class="form-row">
            <label>Store</label>
            {% if locked_store %}
                <input type="text" name="store_number" value="{{ locked_store }}" readonly>
            {% else %}
                <select name="store_number" required>
                    <option value="">Choose store...</option>
                    {% for store in stores %}
                        <option value="{{ store.store_number }}">{{ store.store_number }}{% if store.store_name %} · {{ store.store_name }}{% endif %}</option>
                    {% endfor %}
                </select>
            {% endif %}
        </div>

        <div class="question-list">
            {% for question in questions %}
            <div class="question-card {% if question.is_critical %}critical-question{% endif %}">
                <label class="question-label">
                    {{ question.sort_order }}. {{ question.question_text }}
                    {% if question.is_required %}<span class="required">*</span>{% endif %}
                    {% if question.is_critical %}<span class="critical-pill">Critical</span>{% endif %}
                    {% if question.weight > 0 %}<span class="weight-pill">{{ question.weight }} pts</span>{% endif %}
                </label>

                {% if question.field_type == "long_text" %}
                    <textarea name="question_{{ question.id }}" rows="4" {% if question.is_required %}required{% endif %}></textarea>
                {% elif question.field_type == "yes_no" %}
                    <div class="yes-no-row">
                        <label><input type="radio" name="question_{{ question.id }}" value="Yes" {% if question.is_required %}required{% endif %}> Yes</label>
                        <label><input type="radio" name="question_{{ question.id }}" value="No" {% if question.is_required %}required{% endif %}> No</label>
                    </div>
                {% elif question.field_type == "number" %}
                    <input type="number" step="any" name="question_{{ question.id }}" {% if question.is_required %}required{% endif %}>
                {% elif question.field_type == "date" %}
                    <input type="date" name="question_{{ question.id }}" {% if question.is_required %}required{% endif %}>
                {% elif question.field_type == "dropdown" %}
                    <select name="question_{{ question.id }}" {% if question.is_required %}required{% endif %}>
                        <option value="">Choose...</option>
                        {% for option in get_options(question) %}
                            <option value="{{ option }}">{{ option }}</option>
                        {% endfor %}
                    </select>
                {% else %}
                    <input type="text" name="question_{{ question.id }}" {% if question.is_required %}required{% endif %}>
                {% endif %}
            </div>
            {% endfor %}
        </div>

        <div class="form-actions">
            <button class="btn" type="submit">Submit Form</button>
        </div>
    </form>
</div>

<style>
.bpi-form { margin-top:18px; }
.form-row { display:flex; flex-direction:column; gap:8px; max-width:420px; margin-bottom:18px; }
.form-row label, .question-label { font-weight:800; color:#101828; }
.form-row input, .form-row select, .question-card input[type="text"], .question-card input[type="number"], .question-card input[type="date"], .question-card select, .question-card textarea {
    width:100%; border:1px solid #d0d5dd; border-radius:12px; padding:11px 12px; font:inherit; box-sizing:border-box;
}
.question-list { display:grid; gap:14px; }
.question-card { border:1px solid #eaecf0; border-radius:16px; padding:16px; background:#fff; }
.critical-question { border-color:#fecaca; background:#fffafa; }
.required { color:#dc2626; margin-left:3px; }
.critical-pill, .weight-pill { display:inline-block; margin-left:8px; padding:3px 8px; border-radius:999px; font-size:11px; font-weight:800; }
.critical-pill { background:#fee2e2; color:#991b1b; }
.weight-pill { background:#eef2ff; color:#3730a3; }
.yes-no-row { display:flex; gap:16px; margin-top:12px; }
.yes-no-row label { border:1px solid #d0d5dd; border-radius:12px; padding:10px 14px; min-width:90px; cursor:pointer; }
.form-actions { margin-top:18px; display:flex; justify-content:flex-end; }
@media (max-width: 700px) { .yes-no-row { flex-direction:column; } }
</style>
{% endblock %}
